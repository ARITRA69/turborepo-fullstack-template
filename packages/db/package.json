{
  "name": "@repo/db",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "dev": "bun --env-file ../../.env drizzle-kit studio",
    "db:generate": "bun --env-file ../../.env drizzle-kit generate",
    "db:migrate": "bun --env-file ../../.env drizzle-kit migrate",
    "db:push": "bun --env-file ../../.env drizzle-kit push",
    "db:studio": "bun --env-file ../../.env drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.0",
    "drizzle-zod": "^0.8.3",
    "postgres": "^3.4.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.0",
    "typescript": "5.9.2"
  }
}
